# ⚠️ Générer des mots de passe forts (32+ caractères)
# Exemples :
#   openssl rand -base64 36
#   python - <<'PY'
#   import secrets
#   print(secrets.token_urlsafe(48))
#   PY
DB_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD_32PLUS
DB_DATABASE=melo_nails
DB_USER=melo_wp
DB_PASSWORD=CHANGE_ME_DB_PASSWORD_32PLUS
WP_TABLE_PREFIX=wp_melo_

# =============================
# Réseau / reverse proxy
# =============================
TZ=Europe/Paris
APP_DOMAIN=localhost

